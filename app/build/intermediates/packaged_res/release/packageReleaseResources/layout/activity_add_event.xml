<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thêm sự kiện mới"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/red_primary"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Event Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên sự kiện"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etEventName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nhập tên sự kiện"
            android:padding="12dp"
            android:background="@drawable/edittext_background"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Event Type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loại sự kiện"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerEventType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edittext_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Solar Date -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày dương lịch"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnDatePicker"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Chọn ngày"
                android:textColor="@color/white"
                android:background="@color/red_button"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <EditText
                android:id="@+id/etSolarDay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Ngày"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <EditText
                android:id="@+id/etSolarMonth"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Tháng"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <EditText
                android:id="@+id/etSolarYear"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Năm"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- Lunar Date -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày âm lịch (tự động tính)"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvLunarDay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Ngày"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="16sp"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/tvLunarMonth"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Tháng"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="16sp"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/tvLunarYear"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Năm"
                android:padding="12dp"
                android:background="@drawable/edittext_background"
                android:textSize="16sp"
                android:gravity="center_vertical" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mô tả"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Nhập mô tả sự kiện"
            android:padding="12dp"
            android:background="@drawable/edittext_background"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <!-- Yearly Repeat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/cbYearly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lặp hàng năm theo lịch âm"
                android:textSize="16sp"
                android:textColor="@color/black" />

        </LinearLayout>

        <!-- Notification Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <CheckBox
                android:id="@+id/cbNotification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông báo trước 6 giờ"
                android:textSize="16sp"
                android:textColor="@color/black" />

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Hủy"
                android:textColor="@color/white"
                android:background="@color/red_button"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                android:layout_marginRight="8dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Lưu"
                android:textColor="@color/white"
                android:background="@color/red_button"
                android:textSize="16sp"
                android:layout_marginStart="8dp"
                android:layout_marginLeft="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>